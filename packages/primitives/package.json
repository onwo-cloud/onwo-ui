  "scripts": {
    "build.prepare": "../../scripts/generate-exports.nu ./src/@kit",
    "build": "pnpm run build.prepare && pnpm run build.qwik",
    "build.qwik": "qwik build",
    "build.types": "tsc --emitDeclarationOnly --incremental --pretty",
    "build.lib": "vite build --mode lib -c vite.config.ts",
    "dev": "vite build --mode lib -c ./vite.config.dev.ts",
    "lint": "oxlint",
    "lint.fix": "oxlint --fix",
    "lint.watch": "oxlint --watch",
    "ts-watch": "tsc --emitDeclarationOnly --preserveWatchOutput --pretty --watch"
  },
