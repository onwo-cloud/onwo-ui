{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "lib": ["es2022", "DOM"],
    "jsx": "react-jsx",
    "rootDir": "./src",
    "jsxImportSource": "@qwik.dev/core",
    "declaration": true,
    "declarationDir": "lib-types",
    "declarationMap": true,
    "moduleResolution": "Bundler",
    "incremental": true,
    "types": ["vite/client"],
    "outDir": "./lib",
    "paths": {
      "~primitives/*": ["./src/*"],
      "~primitives/": ["./src/"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": ["./lib", "./lib-types"]
}
