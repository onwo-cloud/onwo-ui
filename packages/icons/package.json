{
  "name": "@onwo/icons",
  "description": "An icon library ported to qwik.js from the moon.io DS",
  "version": "0.0.13-rc.0",
  "private": false,
  "browserslist": [
    "baseline widely available"
  ],
  "keywords": [
    "icon-library",
    "qwik.js",
    "tailwindcss"
  ],
  "license": "MIT",
  "repository": "https://github.com/onwo-cloud/onwo-ui",
  "files": [
    "lib",
    "lib-types"
  ],
  "type": "module",
  "exports": {
    ".": {
      "qwik": "./lib/index.qwik.mjs",
      "import": "./lib/index.qwik.mjs",
      "types": "./lib-types/index.d.ts"
    },
    "./vite": {
      "qwik": "./lib/vite/index.qwik.mjs",
      "import": "./lib/vite/index.qwik.mjs",
      "types": "./lib-types/vite/index.d.ts"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "qwik build",
    "build.types": "tsgo --emitDeclarationOnly --incremental --pretty",
    "build.lib": "vite build --mode lib",
    "dev": "vite build --mode lib -c ./vite.config.dev.ts",
    "lint": "oxlint",
    "lint.fix": "oxlint --fix",
    "lint.watch": "oxlint --watch",
    "ts-watch": "tsgo --emitDeclarationOnly --incremental --preserveWatchOutput --pretty --watch"
  },
  "devDependencies": {
    "@onwo/primitives": "workspace:*",
    "@onwo/tailwindcss": "workspace:*",
    "effect": "^3.21.2",
    "zod": "^4.4.2"
  },
  "engines": {
    "node": "^22"
  },
  "qwik": "./lib/index.qwik.mjs",
  "url": "https://ui.onwo.cloud/"
}
