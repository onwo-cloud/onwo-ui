{
  "name": "@onwo/ui-docs",
  "description": "Documentation website for onwo-ui",
  "version": "0.0.9-alpha",
  "browserslist": [
    "baseline widely available",
    ">0.3%"
  ],
  "private": false,
  "license": "MIT",
  "repository": "https://github.com/onwo-cloud/onwo-ui",
  "type": "module",
  "scripts": {
    "build": "qwik build",
    "build.client": "vite build",
    "build.preview": "vite build --ssr src/entry.preview.tsx",
    "build.server": "qwik check-client src dist && vite build -c adapters/ssg/vite.config.ts",
    "build.types": "tsgo --incremental --noEmit",
    "dev": "vite -c ./vite.config.dev.ts --mode ssr",
    "dev.debug": "node --inspect-brk ./node_modules/vite/bin/vite.js --mode ssr --force",
    "lint": "echo 123",
    "lint.fix": "oxlint --fix",
    "lint.watch": "oxlint --watch",
    "ts-watch": "tsgo --noEmit --incremental --preserveWatchOutput --pretty --watch"
  },
  "dependencies": {
    "@onwo/iconset-lucide": "../packages/icons/packages/iconset-lucide/",
    "@onwo/iconset-mdi": "../packages/icons/packages/iconset-mdi/",
    "effect": "^3.21.2",
    "motion": "^12.38.0"
  },
  "devDependencies": {
    "@onwo/tailwindcss": "workspace:*",
    "playwright": "^1.61.1"
  },
  "engines": {
    "node": "^22"
  },
  "url": "https://ui.onwo.cloud/"
}
